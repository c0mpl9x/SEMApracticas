ltl {
    []!(
        p[0] == L && p[1] == L && p[2] == L &&
        p[3] == e &&
        p[4] == R && p[5] == R && p[6] == R
    )	
}

mtype = { R, e, L };
mtype p[7] = { R, R, R, e, L, L, L };

active proctype frogs() {
    do
    ::if
        :: p[0] == R && p[1] == e -> p[0] = e; p[1] = R 
        :: p[1] == R && p[2] == e -> p[1] = e; p[2] = R 
        :: p[2] == R && p[3] == e -> p[2] = e; p[3] = R 
        :: p[3] == R && p[4] == e -> p[3] = e; p[4] = R 
        :: p[4] == R && p[5] == e -> p[4] = e; p[5] = R 
        :: p[5] == R && p[6] == e -> p[5] = e; p[6] = R 

        :: p[0] == e && p[1] == L -> p[0] = L; p[1] = e 
        :: p[1] == e && p[2] == L -> p[1] = L; p[2] = e 
        :: p[2] == e && p[3] == L -> p[2] = L; p[3] = e 
        :: p[3] == e && p[4] == L -> p[3] = L; p[4] = e 
        :: p[4] == e && p[5] == L -> p[4] = L; p[5] = e 
        :: p[5] == e && p[6] == L -> p[5] = L; p[6] = e 

        :: p[0] == R && p[1] != e && p[2] == e -> p[0] = e; p[2] = R 
        :: p[1] == R && p[2] != e && p[3] == e -> p[1] = e; p[3] = R 
        :: p[2] == R && p[3] != e && p[4] == e -> p[2] = e; p[4] = R 
        :: p[3] == R && p[4] != e && p[5] == e -> p[3] = e; p[5] = R 
        :: p[4] == R && p[5] != e && p[6] == e -> p[4] = e; p[6] = R 

        :: p[0] == e && p[1] != e && p[2] == L -> p[0] = L; p[2] = e 
        :: p[1] == e && p[2] != e && p[3] == L -> p[1] = L; p[3] = e 
        :: p[2] == e && p[3] != e && p[4] == L -> p[2] = L; p[4] = e 
        :: p[3] == e && p[4] != e && p[5] == L -> p[3] = L; p[5] = e 
        :: p[4] == e && p[5] != e && p[6] == L -> p[4] = L; p[6] = e 
      fi ; 
      printf ("%e %e %e %e %e %e %e\n",
              p[0], p[1], p[2], p[3], p[4], p[5], p[6])
    od
}

